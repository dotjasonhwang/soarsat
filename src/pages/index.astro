  <!-- CallToAction Widget *********** -->

  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: 'Call Jason Today',
        href: 'tel:8329009422',
        target: '_self',
        icon: 'lucide:phone',
      },
    ]}
  >
    <Fragment slot="title"> Ready to Raise Your Score? </Fragment>
  </CallToAction>
</Layout>
