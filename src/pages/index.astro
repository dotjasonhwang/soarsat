---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import Pricing from '~/components/widgets/Pricing.astro';
import ScoreMarquee from '~/components/widgets/ScoreMarquee.astro';
import Content from '~/components/widgets/Content.astro';
import headshot from '~/assets/images/headshot.png';
import CallToAction from '~/components/widgets/CallToAction.astro';
import WidgetWrapper from '~/components/ui/WidgetWrapper.astro';
import Headline from '~/components/ui/Headline.astro';
import Button from '~/components/ui/Button.astro';
import { Icon } from 'astro-icon/components';
import planeGraphic from '~/assets/images/plane_graphic.svg';

const metadata = {
  title: 'Soar SAT — SAT Tutoring by 1600-scorer Jason | Houston, TX & Online',
  description:
    'One-on-one SAT tutoring with proven results. Personalized strategies, flexible packages, and real score improvements for high school students.',
  ignoreTitleTemplate: true,
};

const scores = [
  { initials: 'M. I.', before: 1120, after: 1320 },
  { initials: 'J. H.', before: 1430, after: 1540 },
  { initials: 'E. Z.', before: 1150, after: 1390 },
  { initials: 'N. O.', before: 1210, after: 1320 },
  { initials: 'H. K.', before: 1250, after: 1400 },
];
---

<Layout metadata={metadata}>
  <!-- Hero Widget ******************* -->

  <Hero
    actions={[
      {
        variant: 'primary',
        text: 'Call Today',
        href: 'tel:8329009422',
        icon: 'lucide:phone',
      },
    ]}
  >
    <Fragment slot="title">
      Crush the SAT,<br />
      <span class="text-accent"> Tutored by Perfect Scorer</span>
    </Fragment>

    <Fragment slot="subtitle">
      Data-backed SAT tutoring to see sky-high improvements. Taught by Jason Hwang, a 1600-scorer and educator of 10+
      years.
    </Fragment>
  </Hero>

  <img
    src={planeGraphic.src}
    alt=""
    aria-hidden="true"
    class="fixed bottom-[25%] right-[10%] w-48 md:w-96 opacity-40 z-0 pointer-events-none select-none"
  />

  <!-- Pricing Widget **************** -->

  <Pricing
    id="pricing"
    tagline="Tutoring Packages"
    title="Choose Your Path to a Higher Score"
    subtitle="Transparent pricing and structured sessions."
    prices={[
      {
        title: 'A La Carte',
        subtitle: 'For students who want maximum flexibilty.',
        priceRemote: 100,
        priceInPerson: 125,
        items: [{ description: 'Customized Learning Plan' }, { description: 'Flexible Session Scheduling' }],
        callToAction: { text: 'Call Today', href: 'tel:8329009422' },
      },
      {
        title: 'Standard',
        subtitle: '12-hour package. Average students improve 100-150 points.',
        priceRemote: 900,
        priceInPerson: 1125,
        hours: 12,
        items: [
          { description: 'Diagnostics Test & Report' },
          { description: '12 hours of private tutoring' },
          { description: 'Final Practice Test' },
        ],
        callToAction: { text: 'Call Today', href: 'tel:8329009422' },
      },
      {
        title: 'Pro',
        subtitle: '18-hour package. Average students improve 150-200 points.',
        priceRemote: 1170,
        priceInPerson: 1460,
        hours: 18,
        items: [
          { description: 'Diagnostics Test & Report' },
          { description: '18 hours of private tutoring' },
          { description: 'Final Practice Test' },
        ],
        callToAction: { text: 'Call Today', href: 'tel:8329009422' },
      },
    ]}
  />

  <!-- Score Marquee Widget ********** -->

  <ScoreMarquee tagline="Student Results" title="Real Students. Real Score Improvements." scores={scores}>
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-surface"></div>
    </Fragment>
  </ScoreMarquee>

  <!-- About Widget ****************** -->

  <Content
    title="Meet Jason, Your Tutor"
    isReversed
    image={{ src: headshot, alt: 'Jason Hwang, SAT instructor' }}
    items={[
      {
        title: '1600 Scorer',
        description: 'The SAT changes regularly, I keep up by taking practice tests. Most recent 1600: April 2026.',
      },
      {
        title: 'Rice Computer Science Graduate',
        description: 'I use my technical background to teach the SAT with a proprietary data-driven approach.',
      },
      {
        title: '10+ Years of Teaching Experience',
        description: 'I was head TA at Rice University and have been teaching SAT and coding for over a decade.',
      },
    ]}
  >
    <Fragment slot="content">
      Hi, my name is Jason Hwang. In my decade of educational experience, I've found that there are two key factors that
      drive academic success: consistency, and targeted instruction. Consistency is key - regular practice and prep
      beats cramming. Targeted instruction is how students can move past common mistakes and start getting higher
      points. I use a proprietary software which analyzes focus areas for the different sections of the SAT and lets me
      know which topics need extra help. This is how many students see 150+ improvements without having to cram hundreds
      of hours of repetition.
    </Fragment>
  </Content>

  <!-- Free Resource: Test Timeline ** -->

  <WidgetWrapper id="resources">
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-surface"></div>
    </Fragment>
    <Headline tagline="Free Tools" title="Plan Your SAT Journey" />
    <div class="mt-8 md:mt-12 max-w-3xl mx-auto">
      <div
        class="flex flex-col sm:flex-row items-start gap-6 p-6 md:p-8 rounded-2xl bg-surface-elevated border border-primary/30 shadow-sm"
      >
        <div
          class="flex-shrink-0 flex h-14 w-14 items-center justify-center rounded-xl bg-primary/10 text-primary"
          aria-hidden="true"
        >
          <Icon name="lucide:calendar-clock" class="w-7 h-7" />
        </div>
        <div class="flex-1">
          <div class="text-xs font-semibold uppercase tracking-widest text-primary/70 mb-1">Interactive Tool</div>
          <h3 class="text-xl md:text-2xl font-bold text-foreground mb-2">When Should I Take the SAT?</h3>
          <p class="text-base text-muted leading-relaxed mb-4">
            Find the best testing windows based on your graduation year and current grade — including key dates for
            Early Decision and Regular Decision applications.
          </p>
          <Button variant="secondary" text="No Sign-Up Required" href="/tools/timeline" icon="lucide:arrow-right" />
        </div>
      </div>
    </div>
  </WidgetWrapper>

  <!-- Testimonials Widget *********** -->
  <!-- 
  <Testimonials
    id="reviews"
    tagline="What Parents Say"
    title="Trusted by Families Across [Location]"
    testimonials={[
      {
        testimonial:
          "[Placeholder — e.g., 'Our daughter went from a 1180 to a 1430 in 12 sessions. [Tutor Name] is patient, thorough, and genuinely invested in her success. Couldn't recommend more highly.']",
        name: '[Parent Name]',
        job: 'Parent of a [School Name] junior',
      },
      {
        testimonial:
          "[Placeholder — e.g., 'My son dreaded standardized tests. After working with [Tutor Name], he walked in confident. His score jumped 280 points and he's looking at schools we thought were out of reach.']",
        name: '[Parent Name]',
        job: 'Parent of a [School Name] senior',
      },
      {
        testimonial:
          "[Placeholder — e.g., 'Worth every penny. [Tutor Name] found exactly where my daughter was losing points and fixed it methodically. The improvement was dramatic — and fast.']",
        name: '[Parent Name]',
        job: 'Parent of a [School Name] junior',
      },
    ]}
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-surface"></div>
    </Fragment>
  </Testimonials> -->

  <!-- CallToAction Widget *********** -->

  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: 'Call Jason Today',
        href: 'tel:8329009422',
        target: '_self',
        icon: 'lucide:phone',
      },
    ]}
  >
    <Fragment slot="title"> Ready to Raise Your Score? </Fragment>
  </CallToAction>
</Layout>
