---
import type { HTMLTag } from 'astro/types';
import type { Widget } from '~/types';
import { twMerge } from 'tailwind-merge';

export interface Props extends Widget {
  containerClass?: string;
  wrapperClass?: string;
  ['as']?: HTMLTag;
}

const { id, containerClass = '', wrapperClass = '', bg, as = 'section' } = Astro.props;

const WrapperTag = as;
---

<WrapperTag class={twMerge('relative not-prose scroll-mt-[72px]', wrapperClass)} {...id ? { id } : {}}>
  <div class="absolute inset-0 pointer-events-none -z-1" aria-hidden="true">
    <slot name="bg">
      {bg && <Fragment set:html={bg} />}
    </slot>
  </div>
  <div
    class={twMerge(
      'relative mx-auto max-w-7xl px-4 md:px-6 py-12 md:py-16 lg:py-20 text-default animate-together',
      containerClass
    )}
  >
    <slot />
  </div>
</WrapperTag>
