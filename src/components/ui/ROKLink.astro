---
/**
 * ROKLink - A minimal credits link to rokwebsites.com
 *
 * Usage:
 * <ROKLink />
 */
---

<span>
  Site by
  <a
    href="https://rokwebsites.com"
    target="_blank"
    rel="noopener noreferrer"
    class="group relative inline-block font-medium transition-colors duration-300 text-muted hover:text-primary"
  >
    <span class="relative">
      ROK Websites
      <!-- Animated underline -->
      <span class="absolute -bottom-0.5 left-0 h-px w-0 transition-all duration-300 group-hover:w-full bg-primary"
      ></span>
    </span>
  </a>
</span>
