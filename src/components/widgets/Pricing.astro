---
import { Icon } from 'astro-icon/components';
import Button from '~/components/ui/Button.astro';
import Badge from '~/components/ui/Badge.astro';
import Headline from '~/components/ui/Headline.astro';
import WidgetWrapper from '~/components/ui/WidgetWrapper.astro';
import type { Pricing as Props } from '~/types';

const {
  title = '',
  subtitle = '',
  tagline = '',
  prices = [],
  columns = 3,

  id,
  bg = await Astro.slots.render('bg'),
} = Astro.props;

const gridCols =
  columns === 4 ? 'sm:grid-cols-2 lg:grid-cols-4' : columns === 2 ? 'sm:grid-cols-2' : 'sm:grid-cols-2 lg:grid-cols-3';
---

<WidgetWrapper id={id} bg={bg}>
  <Headline title={title} subtitle={subtitle} tagline={tagline} />
  <div class="flex items-stretch justify-center mt-8 md:mt-12">
    <div class={`grid grid-cols-1 gap-4 w-full ${gridCols}`}>
      {
        prices &&
          prices.map(
            ({
              title,
              subtitle,
              price,
              priceRemote,
              priceInPerson,
              hours,
              items,
              callToAction,
              hasRibbon = false,
              ribbonTitle,
            }) => {
              const hourlyRemote = hours && typeof priceRemote === 'number' ? Math.round(priceRemote / hours) : null;
              const hourlyInPerson =
                hours && typeof priceInPerson === 'number' ? Math.round(priceInPerson / hours) : null;
              return (
                <div class="mx-auto flex w-full animate-on-scroll">
                  {(price || priceRemote || priceInPerson) && (
                    <div class="relative rounded-lg backdrop-blur-sm bg-surface-elevated border border-primary/25 shadow-sm px-6 py-8 flex w-full flex-col text-center">
                      {hasRibbon && ribbonTitle && <Badge title={ribbonTitle} />}

                      {/* 1. HEADER */}
                      <div class="px-2 min-h-[5.5rem] md:min-h-[6.5rem]">
                        {title && (
                          <h3 class="text-center text-xl font-semibold uppercase leading-6 tracking-wider mt-2">
                            {title}
                          </h3>
                        )}
                        {subtitle && <p class="font-light sm:text-lg text-muted mt-1">{subtitle}</p>}
                      </div>

                      {/* 2. PRICING */}
                      <div class="px-2 mt-10 md:mt-12">
                        {priceRemote !== undefined && priceInPerson !== undefined ? (
                          <div class="flex items-stretch justify-center gap-3">
                            <div class="flex flex-col items-center gap-1">
                              <span class="text-xs font-semibold uppercase tracking-widest text-muted">Remote</span>
                              <div class="flex items-center">
                                <span class="text-3xl">$</span>
                                <span class="text-4xl font-extrabold">{priceRemote}</span>
                              </div>
                              <span
                                class:list={[
                                  'inline-block rounded-full border border-foreground px-2 py-0.5 text-xs',
                                  { invisible: hourlyRemote === null },
                                ]}
                                aria-hidden={hourlyRemote === null}
                              >
                                {hourlyRemote !== null ? `$${hourlyRemote}/hr` : '\u00A0'}
                              </span>
                            </div>
                            <div class="w-px bg-primary/50 self-stretch" />
                            <div class="flex flex-col items-center gap-1">
                              <span class="text-xs font-semibold uppercase tracking-widest text-muted">In-Person</span>
                              <div class="flex items-center">
                                <span class="text-3xl">$</span>
                                <span class="text-4xl font-extrabold">{priceInPerson}</span>
                              </div>
                              <span
                                class:list={[
                                  'inline-block rounded-full border border-foreground px-2 py-0.5 text-xs',
                                  { invisible: hourlyInPerson === null },
                                ]}
                                aria-hidden={hourlyInPerson === null}
                              >
                                {hourlyInPerson !== null ? `$${hourlyInPerson}/hr` : '\u00A0'}
                              </span>
                            </div>
                          </div>
                        ) : (
                          <div class="flex items-center justify-center text-center mt-1">
                            <span class="text-5xl">$</span>
                            <span class="text-6xl font-extrabold">{price}</span>
                          </div>
                        )}
                      </div>

                      {/* 3. BULLETS */}
                      {items && (
                        <ul class="px-2 mt-10 md:mt-12 space-y-2 text-left">
                          {items.map(
                            ({ description, icon }) =>
                              description && (
                                <li class="flex items-start space-x-3 leading-7">
                                  <div class="rounded-full bg-primary mt-1">
                                    <Icon
                                      name={icon ? icon : 'lucide:check'}
                                      class="w-5 h-5 font-bold p-1 text-on-primary"
                                    />
                                  </div>
                                  <span>{description}</span>
                                </li>
                              )
                          )}
                        </ul>
                      )}

                      {/* 4. CTA */}
                      {callToAction && (
                        <div class="mt-auto pt-6 md:pt-8 flex justify-center">
                          {typeof callToAction === 'string' ? (
                            <Fragment set:html={callToAction} />
                          ) : (
                            callToAction &&
                            callToAction.href && (
                              <Button {...(hasRibbon ? { variant: 'primary' } : {})} {...callToAction} />
                            )
                          )}
                        </div>
                      )}
                    </div>
                  )}
                </div>
              );
            }
          )
      }
    </div>
  </div>
</WidgetWrapper>
