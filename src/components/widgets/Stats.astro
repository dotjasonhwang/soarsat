---
import type { Stats as Props } from '~/types';
import WidgetWrapper from '~/components/ui/WidgetWrapper.astro';
import Headline from '~/components/ui/Headline.astro';
import { Icon } from 'astro-icon/components';

const {
  title = await Astro.slots.render('title'),
  subtitle = await Astro.slots.render('subtitle'),
  tagline,
  stats = [],

  id,
  bg = await Astro.slots.render('bg'),
} = Astro.props;
---

<WidgetWrapper id={id} bg={bg}>
  <Headline title={title} subtitle={subtitle} tagline={tagline} />
  <div class="mt-8 md:mt-12 flex flex-wrap justify-center -m-4 text-center">
    {
      stats &&
        stats.map(({ amount, title, icon }) => (
          <div class="p-4 md:w-1/4 sm:w-1/2 w-full min-w-[220px] text-center md:border-r md:last:border-none md:border-foreground animate-on-scroll">
            {icon && (
              <div class="flex items-center justify-center mx-auto text-primary">
                <Icon name={icon} class="w-10 h-10" />
              </div>
            )}
            {amount && <div class="font-heading text-primary text-5xl font-bold mt-4">{amount}</div>}
            {title && <div class="text-sm font-medium uppercase tracking-widest text-muted lg:text-base">{title}</div>}
          </div>
        ))
    }
  </div>
</WidgetWrapper>
