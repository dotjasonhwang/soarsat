---
import type { CallToAction } from '~/types';
import Button from '~/components/ui/Button.astro';
import WidgetWrapper from '~/components/ui/WidgetWrapper.astro';

export interface Props {
  title?: string;
  subtitle?: string;
  tagline?: string;
  content?: string;
  callToAction?: string | CallToAction;
  callToAction2?: string | CallToAction;
}

const {
  title = await Astro.slots.render('title'),
  subtitle = await Astro.slots.render('subtitle'),
  tagline,
  content = await Astro.slots.render('content'),
  callToAction = await Astro.slots.render('callToAction'),
  callToAction2 = await Astro.slots.render('callToAction2'),
} = Astro.props;
---

<WidgetWrapper wrapperClass="md:-mt-[76px]" containerClass="py-12 md:py-20 pb-8 animate-immediate">
  <div class="pt-0 md:pt-[76px] pointer-events-none"></div>
  <div>
    <div class="text-center max-w-5xl mx-auto">
      {
        tagline && (
          <p class="text-base text-secondary font-bold tracking-wide uppercase animate-immediate" set:html={tagline} />
        )
      }
      {title && <h1 class="text-display animate-immediate" set:html={title} />}
      <div class="max-w-3xl mx-auto">
        {subtitle && <p class="text-xl text-muted mt-4 animate-immediate" set:html={subtitle} />}
        <div
          class="max-w-xs sm:max-w-md m-auto flex flex-nowrap flex-col sm:flex-row sm:justify-center gap-4 mt-6 animate-immediate"
        >
          {
            callToAction && (
              <div class="flex w-full sm:w-auto">
                {typeof callToAction === 'string' ? (
                  <Fragment set:html={callToAction} />
                ) : (
                  <Button variant="primary" {...callToAction} />
                )}
              </div>
            )
          }
          {
            callToAction2 && (
              <div class="flex w-full sm:w-auto">
                {typeof callToAction2 === 'string' ? (
                  <Fragment set:html={callToAction2} />
                ) : (
                  <Button {...callToAction2} />
                )}
              </div>
            )
          }
        </div>
      </div>
      {content && <Fragment set:html={content} />}
    </div>
  </div>
</WidgetWrapper>
