{
  "name": "@onwidget/astrowind",
  "version": "1.0.0-beta.52",
  "description": "AstroWind: A free template using Astro 5.0 and Tailwind CSS. Astro starter theme.",
  "type": "module",
  "private": true,
  "engines": {
    "node": "^18.17.1 || ^20.3.0 || >= 21.0.0"
  },
  "scripts": {
    "dev": "astro dev --host",
    "start": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "check": "npm run check:astro && npm run check:eslint && npm run check:prettier",
    "check:astro": "astro check",
    "check:eslint": "eslint .",
    "check:prettier": "prettier --check .",
    "fix": "npm run fix:eslint && npm run fix:prettier",
    "fix:eslint": "eslint --fix .",
    "fix:prettier": "prettier -w .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:full": "playwright test",
    "test:a11y": "playwright test accessibility",
    "test:all": "npm run test && npm run test:e2e",
    "test:ci": "npm run check && npm run test && npm run test:e2e:full",
    "playwright:install": "playwright install",
    "prepare": "husky"
  },
  "dependencies": {
    "@astrojs/react": "^5.0.5",
    "@astrojs/sitemap": "^3.4.2",
    "@fontsource-variable/inter": "^5.2.5",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "astro": "^5.7.3",
    "astro-embed": "^0.9.0",
    "astro-icon": "^1.1.5",
    "astro-seo": "^1.1.0",
    "limax": "4.1.0",
    "lodash.merge": "^4.6.2",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "unpic": "^4.1.3"
  },
  "overrides": {
    "vite": "6.0.2"
  },
  "lint-staged": {
    "*.{js,ts,astro}": "eslint --fix",
    "*.{js,ts,astro,css,md,json,yaml,yml}": "prettier --write"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.4",
    "@astrojs/mdx": "^4.3.3",
    "@axe-core/playwright": "^4.11.0",
    "@eslint/js": "^9.33.0",
    "@iconify-json/lucide": "^1.2.14",
    "@playwright/test": "^1.54.2",
    "@tailwindcss/typography": "^0.5.18",
    "@tailwindcss/vite": "^4.1.13",
    "@types/eslint__js": "^9.14.0",
    "@types/js-yaml": "^4.0.9",
    "@types/lodash.merge": "^4.6.9",
    "@types/mdx": "^2.0.13",
    "@typescript-eslint/eslint-plugin": "^8.39.0",
    "@typescript-eslint/parser": "^8.39.0",
    "@vitest/coverage-v8": "^3.2.4",
    "@vitest/ui": "^3.2.4",
    "astro-compress": "2.3.8",
    "astro-eslint-parser": "^1.2.2",
    "eslint": "^9.33.0",
    "eslint-plugin-astro": "^1.3.1",
    "eslint-plugin-unused-imports": "^4.2.0",
    "globals": "^16.3.0",
    "happy-dom": "^18.0.1",
    "husky": "^9.1.7",
    "js-yaml": "^4.1.0",
    "lint-staged": "^16.4.0",
    "mdast-util-to-string": "^4.0.0",
    "prettier": "^3.6.2",
    "prettier-plugin-astro": "^0.14.1",
    "reading-time": "^1.5.0",
    "sharp": "0.34.3",
    "tailwind-merge": "^2.6.0",
    "tailwindcss": "^4.1.13",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.39.0",
    "unist-util-visit": "^5.0.0",
    "vitest": "^3.2.4"
  }
}
