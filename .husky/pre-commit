echo "🧪 Running pre-commit checks..."

# Auto-fix staged files (eslint + prettier)
echo "🔧 Running lint-staged (auto-fix)..."
npx lint-staged

if [ $? -ne 0 ]; then
  echo "❌ Lint-staged failed. Commit aborted."
  exit 1
fi

# Run type checks
echo "🔍 Running astro check..."
npm run check:astro

if [ $? -ne 0 ]; then
  echo "❌ Type checks failed. Commit aborted."
  exit 1
fi

# Run unit tests
# echo "📋 Running unit tests..."
# npm run test

# Run build test to ensure project compiles
echo "🔨 Testing build process..."
npm run build

if [ $? -ne 0 ]; then
  echo "❌ Build failed. Commit aborted."
  exit 1
fi

echo "✅ All pre-commit checks passed!"
